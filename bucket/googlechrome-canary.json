            "hash": "ac70e77534acac951aeb06234fd0a91e283e5e876ac50268b7d0c579df5cfc53"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acfwgp76is6s6jvedyj2qzf6zrcq_152.0.7957.0/152.0.7957.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "667069214b9c85174e247b809f70bdf7cbf4c2a2e5b18e913d4084e48c95794c"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/m7wllosrkfbezjkyxo4pdcqhfq_152.0.7956.1/152.0.7956.1_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "f96b761402b70235a28a691fbb4d9e79f41cf137d0a1bbb1ddb8d271818791b4"
